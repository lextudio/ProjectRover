<Window xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="https://github.com/avaloniaui/designer"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:options="clr-namespace:ICSharpCode.ILSpy.Options;assembly=ProjectRover"
  xmlns:properties="clr-namespace:ICSharpCode.ILSpy.Properties;assembly=ProjectRover"
  mc:Ignorable="d"
  x:Class="ICSharpCode.ILSpy.Options.OptionsDialog"
  x:DataType="options:OptionsDialogViewModel"
  Width="800" Height="600"
  Title="{x:Static properties:Resources.Options}">
  <Window.DataTemplates>
    <DataTemplate DataType="options:MiscSettingsViewModel">
      <options:MiscSettingsPanel />
    </DataTemplate>
    <DataTemplate DataType="options:DisplaySettingsViewModel">
      <options:DisplaySettingsPanel />
    </DataTemplate>
    <DataTemplate DataType="options:RoverSettingsViewModel">
      <options:RoverSettingsPanel />
    </DataTemplate>
    <DataTemplate DataType="options:DecompilerSettingsViewModel">
      <options:DecompilerSettingsPanel />
    </DataTemplate>
  </Window.DataTemplates>
  <DockPanel>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
      Margin="12,8">
      <Button Margin="2,0"
              MinWidth="90"
              HorizontalContentAlignment="Center"
              Command="{Binding ResetDefaultsCommand}"
              Content="{x:Static properties:Resources.ResetToDefaults}" />
      <Button Margin="2,0"
              MinWidth="90"
              HorizontalContentAlignment="Center"
              IsDefault="True"
              Click="OnOkClicked"
              Content="{x:Static properties:Resources.OK}" />
      <Button Margin="2,0"
              MinWidth="90"
              HorizontalContentAlignment="Center"
              IsCancel="True"
              Click="OnCancelClicked"
              Content="{x:Static properties:Resources.Cancel}" />
    </StackPanel>

    <TabControl x:Name="OptionsTabControl" ItemsSource="{Binding OptionPages}"
      SelectedValueBinding="{Binding Content, DataType=options:OptionsItemViewModel}"
      SelectedValue="{Binding SelectedPage}">
      <TabControl.ItemTemplate>
        <DataTemplate x:DataType="options:OptionsItemViewModel">
          <TextBlock Text="{Binding Title}" />
        </DataTemplate>
      </TabControl.ItemTemplate>
      <TabControl.ContentTemplate>
        <DataTemplate x:DataType="options:OptionsItemViewModel">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ContentControl Content="{Binding Content}" />
          </ScrollViewer>
        </DataTemplate>
      </TabControl.ContentTemplate>
    </TabControl>
  </DockPanel>
</Window>
